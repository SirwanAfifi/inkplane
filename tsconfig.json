{
  "compilerOptions": {
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES2018",
    "allowJs": false,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "moduleResolution": "Bundler",
    "importHelpers": true,
    "esModuleInterop": true,
    "lib": ["DOM", "ES2018"],
    "types": ["node"],
    "useUnknownInCatchVariables": true
  },
  "include": ["src/**/*.ts", "tests/**/*.ts"]
}
